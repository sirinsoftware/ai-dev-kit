# Codex project config (.codex/config.toml)
# Loads only once you mark this project as "trusted" in Codex.
# Project instructions are read from ./AGENTS.md automatically — no duplication here.

model = "@@CODEX_MODEL@@"
model_reasoning_effort = "@@CODEX_REASONING@@"   # minimal | low | medium | high | xhigh

